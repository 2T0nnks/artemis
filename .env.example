# Artemis — Configuração opcional
# Copie este arquivo para .env e preencha as chaves desejadas

# VirusTotal API Key (opcional)
# Obtenha em: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Brave Search API Key (opcional — ativa a engine Brave)
# Obtenha em: https://api.search.brave.com/
BRAVE_API_KEY=

# Tor Proxy (opcional — rotação de IP via Tor)
# Inicie o Tor Browser ou o serviço `tor` antes de usar.
# Porta padrão do Tor Browser: 9150  |  Serviço tor: 9050
# Para instalar o serviço: https://www.torproject.org/download/tor/
# Com stem instalado (pip install stem), o circuito é renovado a cada 10 requests.
TOR_PROXY=
